# Database (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://teyca:teyca@localhost:5432/teyca
DATABASE_POOL_SIZE=5
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# For burst loads tune together with DB pool:
# max in-flight ~= min(RABBITMQ_CONSUMER_PREFETCH_COUNT, RABBITMQ_CONSUMER_MAX_CONCURRENCY, DATABASE_POOL_SIZE + DATABASE_POOL_MAX_OVERFLOW)
RABBITMQ_CONSUMER_PREFETCH_COUNT=4
RABBITMQ_CONSUMER_MAX_CONCURRENCY=4
RABBITMQ_LOCK_BUSY_RETRY_BASE_DELAY_MS=1000
RABBITMQ_LOCK_BUSY_RETRY_MAX_DELAY_MS=30000
RABBITMQ_LOCK_BUSY_RETRY_MAX_RETRIES=5
RABBITMQ_TEYCA_RATE_LIMIT_RETRY_BASE_DELAY_MS=60000
RABBITMQ_TEYCA_RATE_LIMIT_RETRY_MAX_DELAY_MS=900000
RABBITMQ_TEYCA_RATE_LIMIT_RETRY_MAX_RETRIES=10
EXTERNAL_DISPATCHER_BATCH_SIZE=100
EXTERNAL_DISPATCHER_RETRY_BASE_DELAY_MS=1000
EXTERNAL_DISPATCHER_RETRY_MAX_DELAY_MS=900000
EXTERNAL_DISPATCHER_MAX_RETRIES=25
EXTERNAL_DISPATCHER_TEYCA_RATE_LIMIT_MAX_WAIT_SECONDS=0

# Webhook auth: Teyca sends this value in Authorization header (static token, not JWT)
WEBHOOK_AUTH_ENABLED=true
WEBHOOK_AUTH_TOKEN=your-secret-token-from-teyca
WEBHOOK=/webhook

# Teyca API (outgoing calls: get pass, request merge)
TEYCA_BASE_URL=https://api.teyca.ru
TEYCA_API_KEY=
TEYCA_TOKEN=
TEYCA_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
TEYCA_RATE_LIMIT_REDIS_PREFIX=teyca-rate-limit
TEYCA_ALLOW_LOCAL_RATE_LIMITER=false

# Old DB (read-only, for merge historical data)
EXPORT_DB_URL=postgresql+asyncpg://user:pass@host:5432/export_db
EXPORT_DB_REQUEST_TIMEOUT_SECONDS=15

# Listmonk (Python SDK)
LISTMONK_URL=https://listmonk.example.com
LISTMONK_USER=
LISTMONK_PASSWORD=
LISTMONK_LIST_IDS=1,2
LISTMONK_REQUEST_TIMEOUT_SECONDS=15
LISTMONK_REQUEST_MAX_RETRIES=2
LISTMONK_REQUEST_RETRY_BACKOFF_SECONDS=0.5

# Consent bonus + sync worker
CONSENT_BONUS_AMOUNT=100.0
CONSENT_SYNC_BATCH_SIZE=500

# Loki logging (required)
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
LOG_COMPONENT=app
